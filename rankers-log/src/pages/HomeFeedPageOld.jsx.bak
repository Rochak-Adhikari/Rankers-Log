import { useState, useEffect } from 'react'
import { Link } from 'react-router-dom'
import { supabase } from '../lib/supabase'
import { useAuth } from '../hooks/useAuth'

export function HomeFeedPage() {
  const { user } = useAuth()
  const [posts, setPosts] = useState([])
  const [loading, setLoading] = useState(true)
  const [showCreateModal, setShowCreateModal] = useState(false)
  const [creating, setCreating] = useState(false)
  const [newPost, setNewPost] = useState({
    content: '',
    media_type: 'manga',
    media_title: '',
    progress_type: 'chapter',
    progress_value: 1
  })

  useEffect(() => {
    fetchPosts()
  }, [])

  async function fetchPosts() {
    setLoading(true)
    const { data, error } = await supabase
      .from('posts')
      .select(`
        *,
        profiles:user_id (username, avatar_url, display_name, level, rank)
      `)
      .order('created_at', { ascending: false })
      .limit(20)

    if (!error && data) {
      setPosts(data)
    }
    setLoading(false)
  }

  async function createPost(e) {
    e.preventDefault()
    if (!user || !newPost.media_title.trim()) return

    setCreating(true)
    const xpEarned = calculateXP(newPost.media_type, newPost.progress_type, newPost.progress_value)

    const { data, error } = await supabase
      .from('posts')
      .insert({
        user_id: user.id,
        content: newPost.content,
        media_type: newPost.media_type,
        media_title: newPost.media_title,
        progress_type: newPost.progress_type,
        progress_value: newPost.progress_value,
        xp_earned: xpEarned
      })
      .select(`
        *,
        profiles:user_id (username, avatar_url, display_name, level, rank)
      `)
      .single()

    if (!error && data) {
      setPosts(prev => [data, ...prev])
      setShowCreateModal(false)
      setNewPost({ content: '', media_type: 'manga', media_title: '', progress_type: 'chapter', progress_value: 1 })
    }

    setCreating(false)
  }

  function calculateXP(mediaType, progressType, value) {
    const baseXP = { manga: 10, manhwa: 10, anime: 15, game: 20, novel: 12 }
    const multiplier = progressType === 'completion' ? 5 : 1
    return (baseXP[mediaType] || 10) * value * multiplier
  }

  function formatTimeAgo(dateString) {
    const date = new Date(dateString)
    const now = new Date()
    const seconds = Math.floor((now - date) / 1000)
    if (seconds < 60) return `${seconds}s ago`
    const minutes = Math.floor(seconds / 60)
    if (minutes < 60) return `${minutes}m ago`
    const hours = Math.floor(minutes / 60)
    if (hours < 24) return `${hours}h ago`
    const days = Math.floor(hours / 24)
    return `${days}d ago`
  }

  return (
    <>
      {/* Create Log Modal */}
      {showCreateModal && (
        <div className="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
          <div className="glass-panel rounded-xl w-full max-w-lg p-6 relative">
            <button onClick={() => setShowCreateModal(false)} className="absolute top-4 right-4 text-gray-400 hover:text-white">
              <span className="material-symbols-outlined">close</span>
            </button>
            <h2 className="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <span className="material-symbols-outlined text-primary">add_circle</span>
              Log Activity
            </h2>
            <form onSubmit={createPost} className="space-y-4">
              <div>
                <label className="block text-xs uppercase tracking-wider text-primary mb-1 font-bold">Media Type</label>
                <select
                  value={newPost.media_type}
                  onChange={(e) => setNewPost(p => ({ ...p, media_type: e.target.value }))}
                  className="w-full bg-white/5 border border-white/10 rounded px-3 py-2 text-white focus:border-primary focus:outline-none"
                >
                  <option value="manga">Manga</option>
                  <option value="manhwa">Manhwa</option>
                  <option value="manhua">Manhua</option>
                  <option value="anime">Anime</option>
                  <option value="novel">Novel</option>
                  <option value="game">Game</option>
                </select>
              </div>
              <div>
                <label className="block text-xs uppercase tracking-wider text-primary mb-1 font-bold">Title</label>
                <input
                  type="text"
                  value={newPost.media_title}
                  onChange={(e) => setNewPost(p => ({ ...p, media_title: e.target.value }))}
                  className="w-full bg-white/5 border border-white/10 rounded px-3 py-2 text-white focus:border-primary focus:outline-none"
                  placeholder="e.g. Solo Leveling"
                  required
                />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs uppercase tracking-wider text-primary mb-1 font-bold">Progress Type</label>
                  <select
                    value={newPost.progress_type}
                    onChange={(e) => setNewPost(p => ({ ...p, progress_type: e.target.value }))}
                    className="w-full bg-white/5 border border-white/10 rounded px-3 py-2 text-white focus:border-primary focus:outline-none"
                  >
                    <option value="chapter">Chapter</option>
                    <option value="episode">Episode</option>
                    <option value="volume">Volume</option>
                    <option value="completion">Completion</option>
                  </select>
                </div>
                <div>
                  <label className="block text-xs uppercase tracking-wider text-primary mb-1 font-bold">Value</label>
                  <input
                    type="number"
                    min="1"
                    value={newPost.progress_value}
                    onChange={(e) => setNewPost(p => ({ ...p, progress_value: parseInt(e.target.value) || 1 }))}
                    className="w-full bg-white/5 border border-white/10 rounded px-3 py-2 text-white focus:border-primary focus:outline-none"
                  />
                </div>
              </div>
              <div>
                <label className="block text-xs uppercase tracking-wider text-primary mb-1 font-bold">Notes (Optional)</label>
                <textarea
                  value={newPost.content}
                  onChange={(e) => setNewPost(p => ({ ...p, content: e.target.value }))}
                  rows={3}
                  className="w-full bg-white/5 border border-white/10 rounded px-3 py-2 text-white placeholder-gray-500 focus:border-primary focus:outline-none resize-none"
                  placeholder="Share your thoughts..."
                />
              </div>
              <div className="flex justify-end gap-3 pt-2">
                <button type="button" onClick={() => setShowCreateModal(false)} className="px-4 py-2 text-gray-400 hover:text-white">
                  Cancel
                </button>
                <button
                  type="submit"
                  disabled={creating}
                  className="bg-primary hover:bg-primary/90 disabled:opacity-50 text-white font-bold py-2 px-6 rounded flex items-center gap-2"
                >
                  {creating ? 'Logging...' : 'Log Activity'}
                  <span className="material-symbols-outlined text-sm">send</span>
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* Main Feed Layout */}
      <div className="flex flex-1 pt-4 pb-20 md:pb-8">
        {/* Main Feed Column - Full Width */}
        <main className="flex-1 flex flex-col relative px-4 md:px-12 max-w-4xl mx-auto w-full">
          {/* Filter Tabs */}
          <div className="flex gap-3 pb-8 overflow-x-auto no-scrollbar sticky top-24 z-30 bg-[#050505]/80 backdrop-blur-sm py-4 -mx-4 px-4 md:mx-0 md:px-0">
            <button className="h-8 px-4 rounded-lg bg-primary/20 text-primary border border-primary/30 text-xs font-bold uppercase tracking-wide hover:bg-primary/30 transition-all shrink-0">All Logs</button>
            <button className="h-8 px-4 rounded-lg bg-white/5 text-gray-400 border border-white/10 text-xs font-bold uppercase tracking-wide hover:bg-white/10 hover:text-white transition-all shrink-0">Anime</button>
            <button className="h-8 px-4 rounded-lg bg-white/5 text-gray-400 border border-white/10 text-xs font-bold uppercase tracking-wide hover:bg-white/10 hover:text-white transition-all shrink-0">Manga</button>
            <button className="h-8 px-4 rounded-lg bg-white/5 text-gray-400 border border-white/10 text-xs font-bold uppercase tracking-wide hover:bg-white/10 hover:text-white transition-all shrink-0">Manhwa</button>
            <button className="h-8 px-4 rounded-lg bg-white/5 text-gray-400 border border-white/10 text-xs font-bold uppercase tracking-wide hover:bg-white/10 hover:text-white transition-all shrink-0">Manhua</button>
            <button className="h-8 px-4 rounded-lg bg-white/5 text-gray-400 border border-white/10 text-xs font-bold uppercase tracking-wide hover:bg-white/10 hover:text-white transition-all shrink-0">Novel</button>
            <button className="h-8 px-4 rounded-lg bg-white/5 text-gray-400 border border-white/10 text-xs font-bold uppercase tracking-wide hover:bg-white/10 hover:text-white transition-all shrink-0">Games</button>
          </div>

          {/* Feed - Simple Layout */}
          <div className="relative flex flex-col gap-12 pl-8 md:pl-12">
            {/* Timeline Spine */}
            <div className="absolute left-0 top-0 bottom-0 w-[2px] bg-gradient-to-b from-transparent via-gray-700 to-gray-800 md:left-4"></div>

            {/* Create Input */}
            <div className="relative group">
              <div className="absolute -left-8 md:-left-12 top-9 w-8 md:w-12 h-[2px] bg-gray-700 group-focus-within:bg-primary/70 transition-colors"></div>
              <div className="absolute -left-[36px] md:-left-[52px] top-[30px] h-3 w-3 bg-gray-800 border border-gray-600 rounded-full group-focus-within:border-primary group-focus-within:shadow-[0_0_10px_#258cf4] transition-all z-10"></div>
              <div className="chamfered-box glass-panel p-0 relative group-focus-within:border-primary/50 transition-colors duration-300">
                <div className="flex items-center gap-4 p-4">
                  <div className="h-10 w-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                    <span className="material-symbols-outlined text-gray-400 group-focus-within:text-primary transition-colors">edit_square</span>
                  </div>
                  <input 
                    onClick={() => setShowCreateModal(true)}
                    className="bg-transparent border-none focus:ring-0 text-white placeholder-gray-500 w-full text-sm font-display h-full py-2 cursor-pointer" 
                    placeholder="Log new activity..." 
                    readOnly
                  />
                  <button onClick={() => setShowCreateModal(true)} className="text-gray-500 hover:text-primary transition-colors">
                    <span className="material-symbols-outlined">send</span>
                  </button>
                </div>
              </div>
            </div>

            {loading ? (
              <div className="flex items-center justify-center py-16">
                <span className="material-symbols-outlined text-primary text-4xl animate-pulse">sync</span>
              </div>
            ) : posts.length === 0 ? (
              <div className="chamfered-box glass-panel p-6 text-center">
                <span className="material-symbols-outlined text-gray-600 text-6xl mb-4">inventory_2</span>
                <h3 className="text-xl font-bold text-white mb-2">No Logs Yet</h3>
                <p className="text-gray-500 text-sm mb-6">Start tracking your journey!</p>
                <button 
                  onClick={() => setShowCreateModal(true)}
                  className="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold py-3 px-6 rounded transition-all"
                >
                  <span className="material-symbols-outlined">add</span>
                  Create First Log
                </button>
              </div>
            ) : (
              posts.map((post, index) => {
                const rankColors = ['#FFD700', '#00FFFF', '#BF00FF']
                const rankColor = rankColors[index % 3]
                const rankLabels = ['LEVEL UP', 'STATUS UPDATE', 'NEW QUEST']
                const rankLabel = rankLabels[index % 3]
                const rankIcons = ['workspace_premium', 'visibility', 'bookmark']
                const rankIcon = rankIcons[index % 3]
                
                return (
                  <div key={post.id} className="relative group">
                    {/* Simple Timeline connector */}
                    <div className="absolute -left-8 md:-left-12 top-0 bottom-[-48px] w-[2px] bg-gradient-to-b from-gray-700 to-gray-700 opacity-50"></div>
                    <div className="absolute -left-8 md:-left-12 top-8 w-8 md:w-12 h-[2px]" style={{ background: rankColor, boxShadow: `0 0 8px ${rankColor}` }}></div>
                    <div className="absolute -left-[36px] md:-left-[52px] top-[26px] h-3 w-3 rounded-full z-10 border border-black" style={{ background: rankColor, boxShadow: `0 0 10px ${rankColor}` }}></div>
                    
                    {/* Post Card */}
                    <div className="chamfered-box glass-panel p-0 relative hover:border-white/20 transition-colors duration-300">
                      {/* Post Header */}
                      <div className="flex justify-between items-center p-4 border-b border-white/5" style={{ background: `linear-gradient(to right, ${rankColor}10, transparent)` }}>
                        <div className="flex items-center gap-3">
                          <Link 
                            to={post.profiles ? `/u/${post.profiles.username}` : '#'}
                            className="h-8 w-8 rounded bg-gray-700 bg-cover bg-center"
                            style={{ 
                              border: `1px solid ${rankColor}`,
                              backgroundImage: post.profiles?.avatar_url ? `url('${post.profiles.avatar_url}')` : undefined
                            }}
                          />
                          <div>
                            <div className="flex items-center gap-2">
                              <span className="text-xs font-bold tracking-widest" style={{ color: rankColor, textShadow: `0 0 10px ${rankColor}50` }}>{rankLabel}</span>
                              <span className="text-[10px] text-gray-500">{formatTimeAgo(post.created_at)}</span>
                            </div>
                            <p className="text-sm font-bold text-white">
                              <Link to={post.profiles ? `/u/${post.profiles.username}` : '#'} className="hover:text-primary transition-colors">
                                {post.profiles?.display_name || post.profiles?.username || 'Hunter'}
                              </Link>
                              <span className="text-xs font-normal text-gray-400 ml-1">{post.progress_type === 'completion' ? 'completed' : 'logged progress'}</span>
                            </p>
                          </div>
                        </div>
                        <span className="material-symbols-outlined" style={{ color: rankColor }}>{rankIcon}</span>
                      </div>
                      
                      {/* Post Content */}
                      <div className="p-4">
                        <div className="flex gap-4 items-center mb-3">
                          <div className="w-12 h-16 rounded bg-gray-800 bg-cover bg-center shrink-0 flex items-center justify-center">
                            <span className="material-symbols-outlined text-gray-600">
                              {post.media_type === 'game' ? 'sports_esports' : post.media_type === 'anime' ? 'movie' : 'menu_book'}
                            </span>
                          </div>
                          <div>
                            <h3 className="text-lg font-bold text-white">{post.media_title}</h3>
                            <p className="text-xs text-gray-400 capitalize">{post.media_type} • {post.progress_type} {post.progress_value}</p>
                          </div>
                        </div>
                        {post.content && (
                          <p className="text-sm text-gray-300 line-clamp-2">{post.content}</p>
                        )}
                      </div>
                      
                      {/* Post Actions */}
                      <div className="flex gap-4 p-3 px-4 border-t border-white/5 text-gray-400 text-xs font-medium uppercase tracking-wider">
                        <button className="flex items-center gap-1 hover:text-white transition-colors">
                          <span className="material-symbols-outlined text-lg">thumb_up</span> {post.likes_count || 0}
                        </button>
                        <button className="flex items-center gap-1 hover:text-white transition-colors">
                          <span className="material-symbols-outlined text-lg">comment</span> {post.comments_count || 0}
                        </button>
                        <button className="flex items-center gap-1 hover:text-white transition-colors ml-auto">
                          <span className="material-symbols-outlined text-lg">share</span>
                        </button>
                      </div>
                    </div>
                  </div>
                )
              })
            )}
          </div>
        </main>
      </div>
    </>
  )
}
